# ==========================================================
# HoneyWhale CRM — Variables de entorno (ejemplo)
# Copiar a .env y ajustar valores. NO commitear el .env real.
# ==========================================================

# ----- Entorno general -----
NODE_ENV=development
BUILD_TARGET=development

# ----- API (NestJS) -----
API_PORT=3000

# ----- Puerto público (Nginx) -----
# IMPORTANTE: 8020 está ocupado por INEIN. Usar 8021.
NGINX_PORT=8021

# ----- MySQL -----
MYSQL_ROOT_PASSWORD=cambiar_root_password_seguro
MYSQL_DATABASE=honeywhale_crm
MYSQL_USER=honeywhale
MYSQL_PASSWORD=cambiar_password_seguro

# ----- Redis -----
REDIS_HOST=hw_redis
REDIS_PORT=6379

# ----- JWT -----
JWT_SECRET=cambiar_por_un_secret_largo_aleatorio_min_32_chars
JWT_REFRESH_SECRET=cambiar_por_otro_secret_largo_aleatorio_diferente
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ----- CORS -----
# Usar '*' para cualquier origen, o lista separada por comas (https://a.com,https://b.com)
CORS_ORIGIN=*

# ----- Seeder admin -----
# Si ADMIN_SEED_PASSWORD está vacío, el seeder no crea el usuario por defecto.
ADMIN_SEED_EMAIL=admin@honeywhale.com
ADMIN_SEED_PASSWORD=cambiar-en-produccion

# ----- Cifrado de configuración sensible -----
# 32 bytes en hex (64 caracteres). Generar con: openssl rand -hex 32
# Si se rota, los secretos cifrados anteriores dejan de descifrarse.
CONFIG_ENCRYPTION_KEY=

# ----- Integraciones futuras (placeholders) -----
WOOCOMMERCE_URL=
WOOCOMMERCE_CONSUMER_KEY=
WOOCOMMERCE_CONSUMER_SECRET=
N8N_WEBHOOK_URL=
CHATWOOT_URL=
CHATWOOT_API_TOKEN=
